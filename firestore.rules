rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && getUserData().orgId == orgId;
    }

    function isSuperAdmin() {
      return hasRole('superadmin');
    }

    function isAdmin(orgId) {
      return hasRole('admin') && getUserData().orgId == orgId;
    }

    function isStaff(orgId) {
      return hasRole('staff') && getUserData().orgId == orgId;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Allow user to read their own document
      allow read: if isOwner(userId) || isSuperAdmin() || isAdmin(resource.data.orgId) || isStaff(resource.data.orgId);
      
      // Allow users to update their own non-sensitive fields
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'orgId'])
                    || isSuperAdmin() 
                    || isAdmin(resource.data.orgId);
                    
      // Allow Admins and Staff to create new members for their org
      allow create: if isSuperAdmin() || isAdmin(request.resource.data.orgId) || isStaff(request.resource.data.orgId);
      
      allow delete: if isSuperAdmin() || isAdmin(resource.data.orgId);
    }

    // --- Books Collection ---
    match /books/{bookId} {
      // Anyone in the org can read books, SuperAdmins can read all
      allow read: if isOrgMember(resource.data.orgId) || isSuperAdmin();
      
      // Admins and Staff can manage books in their org
      allow write: if isSuperAdmin() || isAdmin(request.resource.data.orgId) || isStaff(request.resource.data.orgId);
      
      // Specifically for updates and deletes to verify they belong to the org
      allow update, delete: if isSuperAdmin() || isAdmin(resource.data.orgId) || isStaff(resource.data.orgId);
    }

    // --- Transactions Collection ---
    match /transactions/{transactionId} {
      // Org members can read their own transactions; Staff/Admin can read all org transactions
      allow read: if isSuperAdmin() 
                  || isAdmin(resource.data.orgId) 
                  || isStaff(resource.data.orgId) 
                  || (isOrgMember(resource.data.orgId) && isOwner(resource.data.memberId));
                  
      // Admin and Staff can create/update transactions
      allow create: if isSuperAdmin() || isAdmin(request.resource.data.orgId) || isStaff(request.resource.data.orgId);
      allow update: if isSuperAdmin() || isAdmin(resource.data.orgId) || isStaff(resource.data.orgId);
      allow delete: if isSuperAdmin() || isAdmin(resource.data.orgId);
    }
  }
}
